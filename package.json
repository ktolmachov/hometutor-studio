{
  "name": "home-rag-e2e",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke --workers=1",
    "test:e2e:smoke:course-scope": "playwright test --project=smoke --workers=1 tests/e2e/course_scope_activation.spec.ts tests/e2e/course_scope_query_filter.spec.ts tests/e2e/course_scope_deactivation.spec.ts tests/e2e/flashcards_course_generation.spec.ts tests/e2e/golden_delight_graduation_loop.spec.ts",
    "local:course-loop": "npm run test:e2e:smoke:course-scope",
    "test:e2e:nightly": "playwright test --project=nightly",
    "test:e2e:nightly:strict": "set PLAYWRIGHT_NIGHTLY_STRICT=1&& playwright test --project=nightly-strict",
    "test:e2e:demo": "playwright test --project=demo",
    "local:check": ".venv\\Scripts\\python.exe scripts/local_readiness.py",
    "local:check:running": ".venv\\Scripts\\python.exe scripts/local_readiness.py --allow-running --check-running",
    "demo:validate": ".venv\\Scripts\\python.exe scripts/validate_demo_contract.py",
    "demo:list": ".venv\\Scripts\\python.exe scripts/demo_workflow.py list",
    "demo:preflight": ".venv\\Scripts\\python.exe scripts/demo_workflow.py preflight",
    "demo:capture": ".venv\\Scripts\\python.exe scripts/demo_workflow.py capture",
    "demo:preview": ".venv\\Scripts\\python.exe scripts/demo_workflow.py preview",
    "demo:publish": ".venv\\Scripts\\python.exe scripts/demo_workflow.py publish",
    "demo:refresh": ".venv\\Scripts\\python.exe scripts/demo_workflow.py full",
    "demo:scaffold": ".venv\\Scripts\\python.exe scripts/scaffold_demo_scenario.py",
    "validate:team-artifacts": ".venv\\Scripts\\python.exe scripts/validate_team_artifact.py",
    "demo:gifs": ".venv\\Scripts\\python.exe scripts/make_demo_gifs.py",
    "demo:build": "playwright test --project=demo && .venv\\Scripts\\python.exe scripts/make_demo_gifs.py && .venv\\Scripts\\python.exe scripts/generate_demo_doc.py",
    "demo:build:fast": "playwright test --project=demo && .venv\\Scripts\\python.exe scripts/make_demo_gifs.py --no-optimize --colors 64 && .venv\\Scripts\\python.exe scripts/generate_demo_doc.py",
    "demo:kit": "playwright test --project=demo && .venv\\Scripts\\python.exe scripts/make_demo_gifs.py && .venv\\Scripts\\python.exe scripts/generate_demo_doc.py && .venv\\Scripts\\python.exe scripts/build_jury_kit.py",
    "demo:kit:full": "playwright test --project=demo && .venv\\Scripts\\python.exe scripts/make_demo_gifs.py && .venv\\Scripts\\python.exe scripts/generate_demo_doc.py && .venv\\Scripts\\python.exe scripts/build_jury_kit.py --include-details",
    "demo:clean": "node -e \"const fs=require('fs');const rm=p=>{try{fs.rmSync(p,{recursive:true,force:true});}catch{}};rm('doc/screenshots/final');rm('doc/quickstart_demo.md');rm('dist')\"",
    "docs:pdf": "node scripts/render_markdown_pdf.mjs",
    "docs:defense-pdf": "node scripts/render_markdown_pdf.mjs doc/presentations/defense_presentation.md doc/defense_presentation.pdf --title \"home-rag_v2 defense presentation\" --slides --font-scale 1.08 --strip-emoji",
    "docs:defense-pdf:slides": "node scripts/render_markdown_pdf.mjs doc/presentations/defense_presentation_slides.md doc/defense_presentation_slides.pdf --title \"home-rag_v2 defense presentation\" --slides --font-scale 1.15 --strip-emoji",
    "docs:defense-pdf:visual": ".venv\\Scripts\\python.exe scripts/build_defense_visual_deck.py doc/defense_presentation.pdf",
    "docs:defense-pdf:check": ".venv\\Scripts\\python.exe scripts/check_pdf_quality.py doc/defense_presentation.pdf",
    "e2e:install": "playwright install chromium",
    "test:roadmap-sync": ".venv\\Scripts\\python.exe scripts/roadmap_sync_check.py",
    "test:backlog-registry": ".venv\\Scripts\\python.exe scripts/backlog_registry_lint.py",
    "test:portable-paths": ".venv\\Scripts\\python.exe scripts/check_portable_paths.py",
    "test:roadmap-docs": ".venv\\Scripts\\python.exe scripts/roadmap_sync_check.py && .venv\\Scripts\\python.exe scripts/backlog_registry_lint.py",
    "test:loop-gate": ".venv\\Scripts\\python.exe scripts/check_loop_metrics_gate.py",
    "test:loop-gate:record": ".venv\\Scripts\\python.exe scripts/record_loop_metrics_gate_snapshot.py",
    "hooks:install:loop-gate": ".venv\\Scripts\\python.exe scripts/install_loop_gate_pre_push.py",
    "test:loop-gate:summary": ".venv\\Scripts\\python.exe scripts/summarize_loop_metrics_gate_history.py",
    "test:loop-gate:ops": ".venv\\Scripts\\python.exe scripts/record_loop_metrics_gate_snapshot.py && .venv\\Scripts\\python.exe scripts/summarize_loop_metrics_gate_history.py --enforce",
    "test:trigger": "vitest run tests/trigger/",
    "test:trigger:watch": "vitest tests/trigger/"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.12",
    "@playwright/test": "^1.49.1",
    "tsx": "^4.19.2",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@connectrpc/connect-node": "^2.1.2"
  }
}
