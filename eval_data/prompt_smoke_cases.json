          "стоит ",
          "цена",
          "скачать"
        ],
        "require_no_fallback": true,
        "require_model": [
          "qwen/qwen3.6-27b",
          "qwopus3.6-35b-a3b-v1-mtp"
        ],
        "max_reasoning_tokens": 0,
        "allow_missing_reasoning_tokens": true,
        "require_system_user": true
      },
      "review_ru": "Тест B (LM Studio): specs из документа без выдуманных температур/BIOS/цен."
    },
    {
      "id": "lms_profiles_c",
      "query_mode": "qa",
      "question": "Чем отличается fast-профиль от quality-профиля в настройках retrieval?",
      "expect": {
        "min_answer_chars": 60,
        "max_answer_chars": 1800,
        "min_source_count": 1,
        "any_of_substrings": [
          "reranker",
          "rerank",
          "hybrid",
          "vector_only",
          "быстр",
          "fast",
          "quality",
          "вектор",
          "vector",
          "профил"
        ],
        "require_no_fallback": true,
        "require_model": [
          "qwen/qwen3.6-27b",
          "qwopus3.6-35b-a3b-v1-mtp"
        ],
        "max_reasoning_tokens": 0,
        "allow_missing_reasoning_tokens": true,
        "require_system_user": true
      },
      "review_ru": "Тест C (LM Studio): короткое объяснение из KB, без придуманных параметров."
    },
    {
      "id": "lms_neg_d",
      "query_mode": "qa",
      "question": "Какая последняя версия BIOS для ASRock X870E Taichi?",
      "expect": {
        "min_answer_chars": 10,
        "max_answer_chars": 400,
        "any_of_substrings": [
          "контексте",
          "нет",
          "отсутствует",
          "отсутствуют",
          "не найден",
          "не содержат",
          "не могу подтвердить",
          "недостаточно",
          "материалах"
        ],
        "forbidden_substrings": [
          "BIOS 3.",
          "версия 3",
          "скачать с сайта",
          "ASRock.com"
        ],
        "require_no_fallback": true,
        "require_model": [
          "qwen/qwen3.6-27b",
          "qwopus3.6-35b-a3b-v1-mtp"
        ],
        "max_reasoning_tokens": 0,
        "allow_missing_reasoning_tokens": true,
        "require_system_user": true
      },
      "review_ru": "Тест D (LM Studio, negative): BIOS-версии нет в KB. Модель обязана сказать об отсутствии факта, не выдумывать версию. any_of расширен: модель может использовать 'отсутствуют', 'не содержат', 'недостаточно', 'материалах'."
    },
    {
      "id": "lms_neg_e",
      "query_mode": "qa",
      "question": "Какая цена RTX 5070 Ti в магазине DNS?",
      "expect": {
        "min_answer_chars": 10,
        "max_answer_chars": 400,
        "any_of_substrings": [
          "контексте",
          "нет",
          "отсутствует",
          "отсутствуют",
          "не найден",
          "не содержат",
          "не могу подтвердить",
          "недостаточно",
          "материалах"
