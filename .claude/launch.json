{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "kg-preview",
      "runtimeExecutable": ".venv\\Scripts\\python.exe",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", "doc"],
      "port": 8765
    },
    {
      "name": "streamlit",
      "runtimeExecutable": ".venv\\Scripts\\streamlit.exe",
